<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /launchshop/

    # If requesting a real file inside /public (css, js, images etc), serve it
    RewriteCond %{REQUEST_URI} ^/launchshop/public/
    RewriteRule ^ - [L]

    # Route all other requests through public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>
